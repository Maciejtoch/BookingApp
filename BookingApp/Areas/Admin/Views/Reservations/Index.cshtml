@model IEnumerable<BookingApp.Models.Reservation>
@{
    ViewData["Title"] = "Rezerwacje";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Zarządzanie rezerwacjami</h4>
    <div class="btn-group">
        <a asp-area="Admin" asp-controller="Reservations" asp-action="Index"
           class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-dark" : "btn-outline-dark")">Wszystkie</a>
        <a asp-area="Admin" asp-controller="Reservations" asp-action="Index" asp-route-status="Pending"
           class="btn btn-sm @(ViewBag.CurrentStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">Oczekujące</a>
        <a asp-area="Admin" asp-controller="Reservations" asp-action="Index" asp-route-status="Approved"
           class="btn btn-sm @(ViewBag.CurrentStatus == "Approved" ? "btn-success" : "btn-outline-success")">Zatwierdzone</a>
        <a asp-area="Admin" asp-controller="Reservations" asp-action="Index" asp-route-status="Rejected"
           class="btn btn-sm @(ViewBag.CurrentStatus == "Rejected" ? "btn-danger" : "btn-outline-danger")">Odrzucone</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Klient</th>
                    <th>Usługa</th>
                    <th>Data wizyty</th>
                    <th>Złożona</th>
                    <th>Notatki</th>
                    <th>Status</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="text-muted">#@r.Id</td>
                        <td>
                            <div class="fw-semibold">@r.User?.FullName</div>
                            <small class="text-muted">@r.User?.Email</small>
                        </td>
                        <td>@r.Service?.Name</td>
                        <td>@r.Date.ToString("dd.MM.yyyy HH:mm")</td>
                        <td><small class="text-muted">@r.CreatedAt.ToString("dd.MM.yyyy")</small></td>
                        <td><small>@(r.Notes ?? "—")</small></td>
                        <td>
                            <span class="badge rounded-pill
                                    @(r.Status == BookingApp.Models.ReservationStatus.Pending ? "bg-warning text-dark" :
                                                                    r.Status == BookingApp.Models.ReservationStatus.Approved ? "bg-success" :
                                                                    r.Status == BookingApp.Models.ReservationStatus.Rejected ? "bg-danger" : "bg-secondary")">
                                @(r.Status == BookingApp.Models.ReservationStatus.Pending ? "Oczekuje" :
                                                            r.Status == BookingApp.Models.ReservationStatus.Approved ? "Zatwierdzona" :
                                                            r.Status == BookingApp.Models.ReservationStatus.Rejected ? "Odrzucona" : "Anulowana")
                        </span>
                    </td>
                    <td>
                        @if (r.Status == BookingApp.Models.ReservationStatus.Pending)
                            {
                                <form asp-area="Admin" asp-controller="Reservations" asp-action="Approve"
                                      asp-route-id="@r.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-success" title="Zatwierdź">
                                        <i class="fas fa-check"></i>
                                    </button>
                                </form>
                                <form asp-area="Admin" asp-controller="Reservations" asp-action="Reject"
                                      asp-route-id="@r.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-danger" title="Odrzuć">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Brak rezerwacji</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
