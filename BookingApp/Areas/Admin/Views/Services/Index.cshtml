@model IEnumerable<BookingApp.Models.Service>
@{
    ViewData["Title"] = "Usługi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Zarządzanie usługami</h4>
    <a asp-area="Admin" asp-controller="Services" asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Dodaj usługę
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nazwa</th>
                    <th>Opis</th>
                    <th>Cena</th>
                    <th>Czas (min)</th>
                    <th>Rezerwacji</th>
                    <th>Aktywna</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="text-muted">#@s.Id</td>
                        <td class="fw-semibold">@s.Name</td>
                        <td><small class="text-muted">@(s.Description.Length > 60 ? s.Description[..60] + "…" : s.Description)</small></td>
                        <td>@s.Price.ToString("C", new System.Globalization.CultureInfo("pl-PL"))</td>
                        <td>@s.DurationMinutes</td>
                        <td><span class="badge bg-light text-dark">@s.Reservations.Count</span></td>
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="badge bg-success">Tak</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Nie</span>
                            }
                        </td>
                        <td>
                            <a asp-area="Admin" asp-controller="Services" asp-action="Edit"
                               asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-area="Admin" asp-controller="Services" asp-action="Delete"
                                  asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Usunąć usługę @s.Name?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Brak usług</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
