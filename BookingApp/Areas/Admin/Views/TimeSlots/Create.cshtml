@model BookingApp.Models.TimeSlot
@{
    ViewData["Title"] = "Dodaj termin";
}

<div class="card shadow-sm" style="max-width:500px">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="fas fa-clock me-2 text-primary"></i>Nowy termin</h5>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="TimeSlots" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="ServiceId" class="form-label fw-semibold">Usługa</label>
                <select asp-for="ServiceId" class="form-select" asp-items="ViewBag.Services">
                    <option value="">-- Wybierz usługę --</option>
                </select>
                <span asp-validation-for="ServiceId" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="DateTime" class="form-label fw-semibold">Data i godzina</label>
                <input asp-for="DateTime" class="form-control" type="datetime-local"
                       value="@DateTime.Today.AddDays(1).AddHours(9).ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="DateTime" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked />
                <label asp-for="IsAvailable" class="form-check-label">Termin dostępny</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Zapisz
                </button>
                <a asp-area="Admin" asp-controller="TimeSlots" asp-action="Index" class="btn btn-outline-secondary">
                    Anuluj
                </a>
            </div>
        </form>
    </div>
</div>
