@model BookingApp.Models.Reservation
@{
    ViewData["Title"] = "Nowa rezerwacja";
}
<div class="container py-4" style="max-width:600px">
    <h2>Zarezerwuj wizytę</h2>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Usługa</label>
            <select asp-for="ServiceId" asp-items="ViewBag.Services" id="ServiceId" class="form-select">
                <option value="">-- Wybierz usługę --</option>
            </select>
            <span asp-validation-for="ServiceId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Termin</label>
            <select asp-for="TimeSlotId" id="TimeSlotId" class="form-select">
                <option value="">-- Najpierw wybierz usługę --</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>
        <button type="submit" class="btn btn-primary w-100">
            <i class="fas fa-calendar-check me-2"></i>Zarezerwuj
        </button>
    </form>
</div>
